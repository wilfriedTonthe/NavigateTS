<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">



    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Declare camera features as NOT required so the app can install on devices/emulators without camera -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NavigatETS"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".objectsDetection.ObjectDetectionActivity"
            android:exported="false" />
        <activity
            android:name=".objectsDetection.ChairOccupancyActivity"
            android:exported="false" />
        <activity
            android:name=".evaluation.ChairEvaluationActivity"
            android:exported="false"
            android:label="Évaluation Chaises" />
        <activity
            android:name=".describe.DescribeModeChooserActivity"
            android:exported="false"
            android:label="@string/describe_title" />
        <activity
            android:name=".describe.DescribeSceneActivity"
            android:exported="false"
            android:label="@string/describe_photo" />
        <activity
            android:name=".describe.DescribeVideoActivity"
            android:exported="false"
            android:label="@string/describe_video" />
        <activity
            android:name=".objectsResearch.ObjectResearchActivity"
            android:exported="false" />
    </application>

</manifest>